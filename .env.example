# Base URL of the Clodia agent-server API.
# Default if unset: http://localhost:7842
PUBLIC_API_BASE_URL=http://localhost:7842

# Dev-mode bypass of the Claude Max OAuth gate.
#   unset / 0 / false  → auth ENABLED  (production default — login required)
#   1 / true / yes / on → auth DISABLED (the app is usable locally without
#                         completing the OAuth flow; LOGOUT becomes a no-op)
# Baked in at build time like every PUBLIC_ var — re-build to change it.
PUBLIC_AUTH_DISABLED=
